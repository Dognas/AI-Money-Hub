# ==============================================================================
# AI Money Hub — Environment Variables
# Copy this file to .env and fill in real values. Never commit the real .env.
# ==============================================================================

# --- Server -------------------------------------------------------------------
# Port the Node process listens on. Hostinger injects this automatically for
# Node.js Hosting apps — set it manually only for local runs.
PORT=3000

# development | production
NODE_ENV=production

# pino log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# --- Database (Postgres + Drizzle ORM) -----------------------------------------
# Full connection string, e.g. postgres://user:password@host:5432/dbname
# Hostinger: create a PostgreSQL database in hPanel and paste its connection
# string here (or use an external provider like Neon/Supabase).
DATABASE_URL=

# --- Google OAuth (login) ------------------------------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: "Web application"
# Authorized redirect URI: https://YOUR_DOMAIN/api/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Only override if you intentionally point at a different OIDC provider.
# ISSUER_URL=https://accounts.google.com

# --- AI Assistant (Money97 AI™) -------------------------------------------------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Frontend build ---------------------------------------------------------
# Base path the built frontend is served from. Use "/" for a single-process
# deployment (the standard setup used by scripts/copy-client-dist.mjs).
BASE_PATH=/
